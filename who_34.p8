pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--who
--by tib

function _init()
 create_player()
 create_wolf()
 
 timer()
end

function _update()
 player_movement()
 wolf_mouvement()
 udapte_camera()
 thunder()
end

function _draw()
 cls()
 
 flash()
 draw_map()
 draw_player()
 draw_wolf()
 game_over()
 
end 

-->8
--map

function draw_map()  
	  palt(1,true)
	  palt(0,false)
	  circfill(p.x,p.y,34,1) 
	  map(0,0,0,0)
	  palt()  
end  

function can_move(nx, ny)
 offset = 6
 local s= 16
 
 local tx1 = flr((nx+offset)/8)
 local ty1 = flr((ny+offset)/8)
 local tx2 = flr((nx+s-1-offset)/8) 
 local ty2 = flr((ny+offset)/8)
 local tx3 = flr((nx+offset)/8)
 local ty3 = flr((ny+s-1-offset)/8)
 local tx4 = flr((nx+s-1-offset)/8)
 local ty4 = flr((ny+s-1-offset)/8)
 
 if fget(mget(tx1, ty1),0) then return false end
 if fget(mget(tx2, ty2),0) then return false end
 if fget(mget(tx3, ty3),0) then return false end
 if fget(mget(tx4, ty4),0) then return false end
 
 return true
end 

function udapte_camera()
 canx=flr(p.x/115)*115
 cany=flr(p.y/115)*115
 camera(canx*1,cany*1)
 
 local base_x = flr(p.x/115)*115
 local base_y = flr(p.y/115)*115
 
 if timer_shack > 0 then 
  camera(base_x + rnd(4)-2, base_y + rnd(4)-2)
  timer_shack -= 1
 else
  camera(base_x, base_y)
 end  
end 

function timer()
 timer_shack = 0
 timer_flash = 0
end

function flash()
 if timer_flash > 0 then
  pal(0, 7)
  pal(1, 0)
  pal(13, 7)
 else 
  pal()
 end    
end

function thunder()
 if flr(rnd(200)) ==0  then
 timer_flash= 10
 timer_shack= 10
 end 
 
 if timer_flash > 0 then
  timer_flash -= 1
 end  
end  


function died()
 local dx = (w.x + 8) - (p.x + 4)
 local dy = (w.y + 8) - (p.y + 4)
 local distance = sqrt(dx*dx + dy*dy)
 if distance < 8 then
  return true
 else
  return false
 end      
end

function game_over()
 if died() then
  stop("game over looser", 30, 60, 8)
 end
end  
   
-->8
--player

function create_player()
 p={x=8,y=20,ox= 0,oy=0,start_ox=0,start_oy=0,anim_t=0, sprite=33}
 death = false
end 

 

function player_movement()
 local nx, ny = p.x, p.y
 noy,nox =0,0
 if btnp(➡️) then
  nx = p.x + 2 
  nox=-2
  p.flip=false
 elseif btnp(⬅️) then
  nx = p.x - 2
  nox=2 
  p.flip=true
 elseif btnp(⬇️) then
  ny = p.y + 2  
  noy=-2
   
 elseif btnp(⬆️) then
  ny = p.y - 2 
  noy=2
 end
 if can_move(nx, ny) and  (p.x!=nx or p.y!=ny) then
  p.x = nx
  p.y = ny
  p.start_ox=nox
  p.start_oy=noy
  p.anim_t=1
 end
 
 --animation
 p.anim_t -= 0.125 
 if (p.anim_t < 0) p.anim_t = 0
  p.ox=p.start_ox*p.anim_t
  p.oy=p.start_oy*p.anim_t
 if p.anim_t>0.5 then
  p.sprite=64
 else
  p.sprite=33
 end  
 
end 
 
 
function draw_player()
  spr(p.sprite,p.x+p.ox,p.y+p.oy,2,2,p.flip)
  spr(id,x,y,1,1,true)
end


-->8
--wolf


function create_wolf()
 w={x=60,y=60,ox= 0,oy=0,start_ox=0,start_oy=0,anim_t=0, sprite=96}
end






function wolf_mouvement()

 speed = 0.3
--deplacement
 
 if w.x+8 < p.x then
  w.x += speed
  w.flip = true
 elseif w.x > p.x then 
  w.x -= speed
  w.flip=false
 end
  
 if w.y+8 < p.y then
  w.y += speed
  
 elseif w.y > p.y then
  w.y -= speed
 
 end  

--animation

 w.anim_t += 0.125 
 if (w.anim_t > 1) w.anim_t = 0
 w.ox=w.start_ox*w.anim_t
 w.oy=w.start_oy*w.anim_t
 if w.anim_t>0.7 then
  w.sprite=96
 else
  w.sprite=98
 end  
 
end




function draw_wolf()
 if timer_flash == 0 then
  local dx=(w.x+8)-(p.x+8)
  local dy=(p.y+8)-(p.y+8)
  local distance = sqrt(dx*dx+dy*dy)
  if distance > 34 then
   for i=1,15 do
    pal(i,0)
   end
  end    
 
  
  spr(w.sprite,w.x+w.ox,w.y+w.oy,2,2,w.flip) 
  pal() 
 else
  spr(w.sprite,w.x+w.ox,w.y+w.oy,2,2,w.flip)
 end
end


 
